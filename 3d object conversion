# ── COLMAP binary detection (only needed for dense patch_match_stereo) ─────────
def find_colmap_binary():
    for c in ["colmap", "colmap.exe"]:
        p = shutil.which(c)
        if p:
            return p
    for p in [r"C:\Program Files\COLMAP\colmap.exe", r"C:\COLMAP\colmap.exe"]:
        if os.path.isfile(p):
            return p
    return None

