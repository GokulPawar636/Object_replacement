        st.warning("No non‑human objects detected in the first frame. Try a different video.")
    else:
        st.subheader("🔍 Detected object classes")
        selected_classes = []
        cols = st.columns(2)
        for i, cls in enumerate(unique_classes):
            with cols[i % 2]:
                if st.checkbox(cls, key=f"class_{cls}"):
                    selected_classes.append(cls)

        if not selected_classes:
            st.info("Select at least one object class to process.")
        else:
            st.divider()
            st.subheader("📦 3D Model Reconstruction (COLMAP)")
            with st.container():
                col1, col2 = st.columns(2)
                with col1:
                    frame_source = st.radio("Frame source for 3D", ["Raw frames", "Masked frames (object only)"], index=1)
                    recon_type = st.radio("Reconstruction type", ["Sparse (point cloud)", "Dense (mesh + texture)"], index=0)
                with col2:
                    recon_width = st.selectbox("Frame width for reconstruction", [540, 720, 1080], index=1)

            if st.button("🔄 Reconstruct 3D Model", type="primary", use_container_width=True):
                frames_dir = tempfile.mkdtemp()
                try:
                    with st.spinner("Extracting frames..."):
                        use_masks = (frame_source == "Masked frames (object only)")
                        num_frames = extract_raw_frames(tmp_path, frames_dir, selected_classes, use_masks, recon_width)
                        st.info(f"Extracted {num_frames} frames.")

                    if num_frames < 5:
                        st.error("Too few frames (need at least 5). Try a longer video or reduce frame width.")
                    else:
                        out_dir = tempfile.mkdtemp()
                        with st.spinner("Running COLMAP (this may take a while)..."):
                            sparse_only = (recon_type == "Sparse (point cloud)")
                            model_path = run_colmap_on_frames(frames_dir, out_dir, sparse_only)

                        if model_path and os.path.exists(model_path):
                            zip_buffer = io.BytesIO()
                            with zipfile.ZipFile(zip_buffer, 'w', zipfile.ZIP_DEFLATED) as zf:
                                # Add the main output file
                                zf.write(model_path, os.path.basename(model_path))
                                # Also add the entire sparse/dense folders for completeness
                                if sparse_only:
                                    # Add sparse folder (cameras, images, points)
                                    for root, _, files in os.walk(os.path.join(out_dir, "sparse")):
                                        for file in files:
                                            full_path = os.path.join(root, file)
                                            arcname = os.path.relpath(full_path, out_dir)
                                            zf.write(full_path, arcname)
                                else:
                                    # Add the dense folder (meshed.ply and texture if any)
                                    for root, _, files in os.walk(os.path.join(out_dir, "dense")):
                                        for file in files:
                                            full_path = os.path.join(root, file)
                                            arcname = os.path.relpath(full_path, out_dir)
                                            zf.write(full_path, arcname)
                            zip_buffer.seek(0)
                            st.success("3D reconstruction completed!")
                            st.download_button(
                                label="📥 Download 3D Model (ZIP)",
                                data=zip_buffer,
                                file_name="object_3d_model.zip",
                                mime="application/zip",
                                use_container_width=True
                            )
                        else:
                            st.error("COLMAP reconstruction failed. Check the frames (need enough texture and motion).")
                except Exception as e:
                    st.error(f"An error occurred: {e}")
                finally:
                    shutil.rmtree(frames_dir, ignore_errors=True)
                    if 'out_dir' in locals():
                        shutil.rmtree(out_dir, ignore_errors=True)

            st.divider()
            st.subheader("🎨 2D Mesh Frames (Delaunay)")
            if st.button("▶️ Generate 2D Mesh Frames", type="secondary", use_container_width=True):
                color_bgr = hex_bgr(mesh_color_hex)
                img_dir, frames_processed, elapsed = process_video_save_frames(
                    tmp_path, selected_classes, color_bgr,
                    grid_step, line_thick, show_nodes, output_w, mesh_only
                )
                st.success(f"✅ Done – {frames_processed} frames · {elapsed:.1f}s · {frames_processed/elapsed:.1f} fps")

                zip_buffer = io.BytesIO()
                with zipfile.ZipFile(zip_buffer, 'w', zipfile.ZIP_DEFLATED) as zip_file:
                    for root, _, files in os.walk(img_dir):
                        for file in files:
                            file_path = os.path.join(root, file)
                            arcname = os.path.relpath(file_path, img_dir)
                            zip_file.write(file_path, arcname)
                zip_buffer.seek(0)

                st.download_button(
                    label="📥 Download 2D Mesh Frames (ZIP)",
                    data=zip_buffer,
                    file_name="object_mesh_frames.zip",
                    mime="application/zip",
                    use_container_width=True
                )
                shutil.rmtree(img_dir, ignore_errors=True)

    # Clean up the temporary video file
    try:
        os.unlink(tmp_path)
    except:
        pass
