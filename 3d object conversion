# ── Mask helpers ───────────────────────────────────────────────────────────────
def get_mask(frame, selected_classes):
    h, w = frame.shape[:2]
    results = yolo(frame, conf=conf_thresh, verbose=False)[0]
    combined = np.zeros((h, w), dtype=np.uint8)
    if results.masks is None:
        return combined
    for mask_t, cls_t in zip(results.masks.data.cpu().numpy(),
                              results.boxes.cls.cpu().numpy()):
        cls_name = yolo.names[int(cls_t)]
        if cls_name.lower() == "person" or cls_name not in selected_classes:
            continue
        bin_mask = (mask_t > 0.5).astype(np.uint8) * 255
        if bin_mask.shape != (h, w):
            bin_mask = cv2.resize(bin_mask, (w, h), interpolation=cv2.INTER_NEAREST)
        combined = cv2.bitwise_or(combined, bin_mask)
    k = np.ones((7, 7), np.uint8)
    combined = cv2.morphologyEx(combined, cv2.MORPH_OPEN,  k)
    combined = cv2.morphologyEx(combined, cv2.MORPH_CLOSE, k)
    cnts, _ = cv2.findContours(combined, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    if cnts:
        best = max(cnts, key=cv2.contourArea)
        out  = np.zeros_like(combined)
        cv2.drawContours(out, [best], -1, 255, -1)
        return out
    return combined


def apply_background(frame_bgr, mask, mode):
    fg = frame_bgr.copy()
    if mode == "White":
        fg[mask == 0] = 255
    elif mode == "Black":
        fg[mask == 0] = 0
    else:
        fg[mask == 0] = cv2.GaussianBlur(frame_bgr, (55, 55), 0)[mask == 0]
    return fg


def extract_frames(video_path, selected_classes, out_dir, bg_mode,
                   frame_width, frame_skip, max_frames):
    cap    = cv2.VideoCapture(video_path)
    orig_w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    orig_h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    out_h  = int(orig_h * frame_width / max(orig_w, 1)) & ~1

    saved, idx, prev_mask = 0, 0, None
    bar = st.progress(0, "Extracting frames…")

    while saved < max_frames:
        ret, frame = cap.read()
        if not ret:
            break
        if idx % frame_skip != 0:
            idx += 1
            continue
        mask = get_mask(frame, selected_classes)
        if np.sum(mask) == 0:
            if prev_mask is not None:
                mask = prev_mask.copy()
            else:
                idx += 1
                continue
        else:
            prev_mask = mask.copy()

        frame_rs  = cv2.resize(frame, (frame_width, out_h))
        mask_rs   = cv2.resize(mask,  (frame_width, out_h),
                               interpolation=cv2.INTER_NEAREST)
        cv2.imwrite(
            os.path.join(out_dir, f"{saved:06d}.jpg"),
            apply_background(frame_rs, mask_rs, bg_mode),
            [cv2.IMWRITE_JPEG_QUALITY, 95],
        )
        saved += 1
        bar.progress(min(saved / max_frames, 1.0), f"Frame {saved}/{max_frames}")
        idx += 1

    cap.release()
    bar.empty()
    return saved


# ── COLMAP pipeline (pycolmap 4.x API only — no broken CLI flags) ──────────────
def run_sparse_sfm(image_dir, work_dir):
    db_path    = os.path.join(work_dir, "database.db")
    sparse_dir = os.path.join(work_dir, "sparse")
    os.makedirs(sparse_dir, exist_ok=True)

    # ── upgrade pycolmap to 4.x if needed ─────────────────────────────────────
    if not hasattr(pycolmap, "FeatureExtractionOptions"):
        st.warning("pycolmap is outdated — upgrading to 4.x…")
        subprocess.check_call(
            [sys.executable, "-m", "pip", "install", "--upgrade", "pycolmap", "--quiet"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        st.warning("✅ Upgraded. Please **restart the app** (Ctrl+C → streamlit run app.py).")
        st.stop()

    # ── Feature extraction — no options objects, bare minimum args ─────────────
    st.info("🔍 Extracting SIFT features…")
    pycolmap.extract_features(
        database_path=db_path,
        image_path=image_dir,
        camera_mode=pycolmap.CameraMode.SINGLE,
    )
    st.success("✅ Features extracted")

    # ── Exhaustive matching ────────────────────────────────────────────────────
    st.info("🔗 Exhaustive feature matching…")
    pycolmap.match_exhaustive(database_path=db_path)
    st.success("✅ Matching done")

    # ── Incremental mapping ────────────────────────────────────────────────────
    st.info("📐 Sparse SfM (incremental mapping)…")
    maps = pycolmap.incremental_mapping(
        database_path=db_path,
        image_path=image_dir,
        output_path=sparse_dir,
    )
    if not maps:
        st.error(
            "❌ Sparse reconstruction failed.\n\n"
            "**Common causes:**\n"
            "- Camera doesn't move enough around the object\n"
            "- Too few frames with matching features\n"
            "- Object has no texture (plain surfaces, glass, metal)\n\n"
            "Try: more frames, slower orbit, better lighting."
        )
        return None, None

    model = maps[0]
    model.write(sparse_dir)
    st.success(f"✅ Sparse model: {len(model.images)} images · {len(model.points3D):,} 3D points")
    return model, sparse_dir

def run_dense_stereo_binary(sparse_dir, image_dir, work_dir, dense_quality):
    """
    Dense stereo using COLMAP binary (supports CUDA).
    Called only when COLMAP_BIN is found.
    """
    dense_dir = os.path.join(work_dir, "dense")
    os.makedirs(dense_dir, exist_ok=True)

    q_map = {
        "low":    ("1000", "4", "3"),
        "medium": ("2000", "5", "5"),
        "high":   ("3200", "7", "7"),
    }
    max_img, win_r, num_it = q_map.get(dense_quality, q_map["medium"])

    # Undistort using binary
    st.info("🔧 Undistorting images (binary)…")
    cmd = [
        COLMAP_BIN, "image_undistorter",
        "--image_path",  image_dir,
        "--input_path",  os.path.join(sparse_dir, "0") if os.path.isdir(os.path.join(sparse_dir, "0")) else sparse_dir,
        "--output_path", dense_dir,
        "--output_type", "COLMAP",
    ]
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        st.warning(f"Undistort (binary) failed:\n{r.stderr[-1000:]}")
        return None

    # Patch-match stereo
    st.info(f"🖥️ Patch-match stereo (binary CUDA, quality={dense_quality})…")
    cmd = [
        COLMAP_BIN, "patch_match_stereo",
        "--workspace_path",   dense_dir,
        "--workspace_format", "COLMAP",
    ]
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        st.warning(f"Patch-match stereo (binary) failed:\n{r.stderr[-1000:]}")
        return None

    # Stereo fusion
    st.info("🔗 Stereo fusion (binary)…")
    fused = os.path.join(dense_dir, "fused.ply")
    cmd = [
        COLMAP_BIN, "stereo_fusion",
        "--workspace_path",   dense_dir,
        "--workspace_format", "COLMAP",
        "--input_type",       "geometric",
        "--output_path",      fused,
    ]
    r = subprocess.run(cmd, capture_output=True, text=True)
    if r.returncode != 0:
        st.warning(f"Stereo fusion (binary) failed:\n{r.stderr[-1000:]}")
        return None

    return fused if os.path.exists(fused) else None


def run_dense_stereo_pycolmap(sparse_dir, image_dir, work_dir, dense_quality):
    """
    Dense stereo using pycolmap Python API (CPU if no CUDA wheel).
    """
    dense_dir = os.path.join(work_dir, "dense")
    os.makedirs(dense_dir, exist_ok=True)

    # Undistort
    st.info("🔧 Undistorting images (pycolmap)…")
    pycolmap.undistort_images(
        output_path=dense_dir,
        input_path=sparse_dir,
        image_path=image_dir,
    )

    # Patch-match stereo
    st.info("🖥️ Dense stereo (pycolmap — CPU, may be slow)…")
    pm_opts = pycolmap.PatchMatchOptions()
    pm_opts.max_image_size = frame_width
    pm_opts.num_iterations = {"low": 3, "medium": 5, "high": 7}.get(dense_quality, 5)

    pycolmap.patch_match_stereo(
        workspace_path=dense_dir,
        workspace_format="COLMAP",
        options=pm_opts,
    )

    # Stereo fusion
    st.info("🔗 Fusing depth maps (pycolmap)…")
    fused = os.path.join(dense_dir, "fused.ply")
    pycolmap.stereo_fusion(
        output_path=fused,
        workspace_path=dense_dir,
        workspace_format="COLMAP",
        options=pycolmap.StereoFusionOptions(),
    )

    return fused if os.path.exists(fused) else None


def sparse_model_to_ply(model, out_path):
    """Export sparse point cloud as PLY (fallback when dense fails)."""
    pts = model.points3D
    if not pts:
        return None
    with open(out_path, "w") as f:
        f.write("ply\nformat ascii 1.0\n")
        f.write(f"element vertex {len(pts)}\n")
        f.write("property float x\nproperty float y\nproperty float z\n")
        f.write("property uchar red\nproperty uchar green\nproperty uchar blue\n")
        f.write("end_header\n")
        for pt in pts.values():
            x, y, z = pt.xyz
            r, g, b = pt.color
            f.write(f"{x:.6f} {y:.6f} {z:.6f} {int(r)} {int(g)} {int(b)}\n")
    return out_path


# ── Open3D: point cloud → mesh ─────────────────────────────────────────────────
def build_mesh(ply_path, poisson_depth, out_dir, texture_size):
    st.info("📦 Loading point cloud…")
    pcd   = o3d.io.read_point_cloud(ply_path)
    n_pts = len(pcd.points)
    st.write(f"   Points: {n_pts:,}")

    if n_pts < 100:
        st.error(
            "Point cloud too sparse to mesh. "
            "Try more frames, slower orbit, or better lighting/texture on the object."
        )
        return None, None, None

    st.info("🧹 Statistical outlier removal…")
    pcd, _ = pcd.remove_statistical_outlier(nb_neighbors=20, std_ratio=2.0)

    st.info("📐 Estimating normals…")
    pcd.estimate_normals(
        search_param=o3d.geometry.KDTreeSearchParamHybrid(radius=0.1, max_nn=30))
    pcd.orient_normals_consistent_tangent_plane(100)

    st.info(f"🌊 Poisson surface reconstruction (depth={poisson_depth})…")
    mesh, densities = o3d.geometry.TriangleMesh.create_from_point_cloud_poisson(
        pcd, depth=poisson_depth, width=0, scale=1.1, linear_fit=False)
    density_arr = np.asarray(densities)
    mesh.remove_vertices_by_mask(density_arr < np.percentile(density_arr, 5))
    mesh.compute_vertex_normals()
    st.write(f"   Mesh: {len(mesh.vertices):,} verts · {len(mesh.triangles):,} tris")

    # Bake vertex colours from point cloud
    st.info("🎨 Baking vertex colours…")
    tree     = o3d.geometry.KDTreeFlann(pcd)
    pcd_cols = np.asarray(pcd.colors)
    cols     = []
    for v in np.asarray(mesh.vertices):
        [_, idx, _] = tree.search_knn_vector_3d(v, 1)
        cols.append(pcd_cols[idx[0]])
    mesh.vertex_colors = o3d.utility.Vector3dVector(np.array(cols))

    verts   = np.asarray(mesh.vertices)
    tris    = np.asarray(mesh.triangles)
    colours = np.asarray(mesh.vertex_colors)

    obj_path = os.path.join(out_dir, "object_mesh.obj")
    mtl_path = os.path.join(out_dir, "object_mesh.mtl")
    tex_path = os.path.join(out_dir, "object_texture.png")

    st.info("💾 Writing .obj…")
    with open(obj_path, "w") as f:
        f.write("# 3D mesh — Object Mesh App\nmtllib object_mesh.mtl\n\n")
        for v, c in zip(verts, colours):
            f.write(f"v {v[0]:.6f} {v[1]:.6f} {v[2]:.6f} "
                    f"{c[0]:.4f} {c[1]:.4f} {c[2]:.4f}\n")
        f.write("\nusemtl material0\n\n")
        for t in tris:
            f.write(f"f {t[0]+1} {t[1]+1} {t[2]+1}\n")

    # Colour atlas
    tex = np.zeros((texture_size, texture_size, 3), dtype=np.uint8)
    n_c = max(int(np.sqrt(len(colours))) + 1, 1)
    csz = max(1, texture_size // n_c)
    for i, c in enumerate(colours):
        gy, gx = (i // n_c) * csz, (i % n_c) * csz
        tex[gy:min(gy+csz, texture_size), gx:min(gx+csz, texture_size)] = (
            int(c[2]*255), int(c[1]*255), int(c[0]*255))
    cv2.imwrite(tex_path, tex)

    with open(mtl_path, "w") as f:
        f.write("newmtl material0\nKa 1 1 1\nKd 1 1 1\nKs 0 0 0\n"
                "map_Kd object_texture.png\n")

    st.success(f"✅ Mesh ready: {len(verts):,} verts · {len(tris):,} tris")
    return obj_path, mtl_path, tex_path


# ── Main UI ────────────────────────────────────────────────────────────────────
uploaded = st.file_uploader(
    "📹 Upload video — walk slowly all the way around the object",
    type=["mp4", "avi", "mov", "mkv"],
)

if uploaded:
    st.video(uploaded)

    with tempfile.NamedTemporaryFile(delete=False, suffix=".mp4") as tmp:
        tmp.write(uploaded.read())
        tmp_path = tmp.name

    cap = cv2.VideoCapture(tmp_path)
    ret, first_frame = cap.read()
    total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    cap.release()

    if not ret:
        st.error("Could not read video.")
        st.stop()

    with st.spinner("Detecting objects in first frame…"):
        res = yolo(first_frame, conf=conf_thresh, verbose=False)[0]
        unique_classes = []
        if res.boxes is not None:
            unique_classes = sorted(set(
                yolo.names[int(c)]
                for c in res.boxes.cls.cpu().numpy()
                if yolo.names[int(c)].lower() != "person"
            ))

    if not unique_classes:
        st.warning("No non-human objects detected. Lower the confidence threshold.")
        st.stop()

    st.subheader("🔍 Detected objects — select what to reconstruct")
    selected_classes = []
    cols = st.columns(3)
    for i, cls in enumerate(unique_classes):
        with cols[i % 3]:
            if st.checkbox(cls, key=f"cls_{cls}"):
                selected_classes.append(cls)

    if not selected_classes:
        st.info("☝️ Select at least one object class above.")
        st.stop()

    st.divider()
    est = min(max_frames, total_frames // max(frame_skip, 1))
    dense_backend = "COLMAP binary (CUDA)" if COLMAP_BIN else "pycolmap (CPU)"
    st.info(
        f"**Estimated COLMAP frames:** ~{est}  \n"
        f"**Dense stereo backend:** {dense_backend}  \n"
        f"**Dense quality:** `{dense_quality}`  \n"
        f"**Output:** `object_mesh.obj` + `object_mesh.mtl` + `object_texture.png` + `fused.ply`"
    )

    if st.button("🚀 Start 3D Reconstruction", type="primary", use_container_width=True):
        frames_dir = tempfile.mkdtemp()
        work_dir   = tempfile.mkdtemp()
        out_dir    = tempfile.mkdtemp()

        try:
            # ── Step 1: frame extraction ───────────────────────────────────────
            st.subheader("Step 1 / 4 — Frame extraction")
            n = extract_frames(tmp_path, selected_classes, frames_dir,
                               bg_mode, frame_width, frame_skip, max_frames)
            st.success(f"✅ {n} frames extracted")
            if n < 10:
                st.error("Too few frames (<10). Use a longer video or smaller frame_skip.")
                st.stop()

            samples = sorted(os.listdir(frames_dir))[:4]
            c4 = st.columns(4)
            for col, fname in zip(c4, samples):
                img = cv2.imread(os.path.join(frames_dir, fname))
                col.image(cv2.cvtColor(img, cv2.COLOR_BGR2RGB),
                          caption=fname, use_container_width=True)

            # ── Step 2a: sparse SfM (always via pycolmap Python API) ───────────
            st.subheader("Step 2 / 4 — Sparse SfM + Dense stereo")
            model, sparse_dir = run_sparse_sfm(frames_dir, work_dir)
            if model is None:
                st.stop()

            # ── Step 2b: dense stereo ──────────────────────────────────────────
            fused_ply = None

            if COLMAP_BIN:
                st.info(f"🚀 Dense stereo: COLMAP binary `{COLMAP_BIN}` (CUDA)")
                fused_ply = run_dense_stereo_binary(
                    sparse_dir, frames_dir, work_dir, dense_quality)

            if fused_ply is None:
                st.warning(
                    "Dense stereo via binary failed or unavailable — "
                    "trying pycolmap (CPU)…"
                )
                try:
                    fused_ply = run_dense_stereo_pycolmap(
                        sparse_dir, frames_dir, work_dir, dense_quality)
                except Exception as e:
                    st.warning(f"pycolmap dense stereo also failed: {e}")

            if fused_ply is None or not os.path.exists(fused_ply):
                st.warning(
                    "⚠️ Dense stereo failed — falling back to **sparse** point cloud.  \n"
                    "The mesh will be lower quality. For dense, ensure the COLMAP binary "
                    "is on your PATH and your GPU supports CUDA."
                )
                sparse_ply = os.path.join(work_dir, "sparse_cloud.ply")
                fused_ply  = sparse_model_to_ply(model, sparse_ply)
                if fused_ply is None:
                    st.error("Sparse export also failed. Reconstruction incomplete.")
                    st.stop()

            # ── Step 3: Poisson mesh ───────────────────────────────────────────
            st.subheader("Step 3 / 4 — Poisson mesh + texture")
            obj_path, mtl_path, tex_path = build_mesh(
                fused_ply, poisson_depth, out_dir, texture_size)
            if obj_path is None:
                st.stop()

            # ── Step 4: package ZIP ────────────────────────────────────────────
            st.subheader("Step 4 / 4 — Packaging download")
            zip_buf = io.BytesIO()
            with zipfile.ZipFile(zip_buf, "w", zipfile.ZIP_DEFLATED) as zf:
                zf.write(obj_path,  "object_mesh.obj")
                zf.write(mtl_path,  "object_mesh.mtl")
                zf.write(tex_path,  "object_texture.png")
                zf.write(fused_ply, os.path.basename(fused_ply))
                if os.path.isdir(sparse_dir):
                    for root, _, files in os.walk(sparse_dir):
                        for fname in files:
                            fp = os.path.join(root, fname)
                            zf.write(fp, os.path.join(
                                "sparse", os.path.relpath(fp, sparse_dir)))
            zip_buf.seek(0)

            st.success("🎉 3D reconstruction complete!")
            st.balloons()
            st.markdown("""
### 📂 ZIP contents
| File | Description |
|------|-------------|
| `object_mesh.obj` | 3D mesh with vertex colours |
| `object_mesh.mtl` | Material definition |
| `object_texture.png` | Colour texture atlas |
