#  UV UNWRAP
# ══════════════════════════════════════════════════════════════════════════════

def run_uv(mesh):
    pos   = np.ascontiguousarray(mesh.vertices,       np.float32)
    faces = np.ascontiguousarray(mesh.faces,          np.uint32)
    norms = np.ascontiguousarray(mesh.vertex_normals, np.float32)
    pos   = np.nan_to_num(pos); norms = np.nan_to_num(norms)
    vmapping, indices, uvs = xatlas.parametrize(pos, faces, norms)
    uvs_2d     = np.array(uvs,     np.float32).reshape(-1,2)
    indices_2d = np.clip(np.array(indices, np.int32).reshape(-1,3), 0, len(uvs_2d)-1)
    return vmapping, indices_2d, uvs_2d


def uv_figure(uvs_2d, indices_2d):
    fig, ax = plt.subplots(figsize=(5,5), facecolor="#111318")
    ax.set_facecolor("#161b22")

    segs = []
    step = max(1, len(indices_2d)//6000)
    for fi in range(0, len(indices_2d), step):
        tri = uvs_2d[indices_2d[fi]]
        for a,b in [(0,1),(1,2),(2,0)]:
            segs.append([tri[a].tolist(), tri[b].tolist()])
    if segs:
        ax.add_collection(mc.LineCollection(segs, colors="#388bfd",
                                            linewidths=0.35, alpha=0.7))
    ax.set_xlim(0,1); ax.set_ylim(0,1); ax.set_aspect("equal")
    ax.set_title("UV Atlas", color="#79c0ff", fontsize=11, pad=6)
    ax.set_xlabel("U",color="#8b949e"); ax.set_ylabel("V",color="#8b949e")
    ax.tick_params(colors="#8b949e")
    for sp in ax.spines.values(): sp.set_edgecolor("#30363d")
    ax.set_xticks(np.arange(0,1.1,0.25)); ax.set_yticks(np.arange(0,1.1,0.25))
    ax.grid(color="#30363d",linewidth=0.4,alpha=0.5)
    buf=io.BytesIO()
    fig.savefig(buf,format="png",dpi=140,bbox_inches="tight",facecolor=fig.get_facecolor())
    buf.seek(0); plt.close(fig)
    return buf


