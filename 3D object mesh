    for row in match_log:
        if row["status"] == "ok":
            st.markdown(
                f'<div class="match-ok">✅ <b>{row["mesh"]}</b>'
                f' → {row["texture"]}'
                f'&nbsp;&nbsp;<span style="opacity:0.6">[{row["uv_source"]}]'
                f' · {row["verts"]:,}v · {row["faces"]:,}f</span></div>',
                unsafe_allow_html=True)
        elif row["status"] == "miss":
            st.markdown(
                f'<div class="match-miss">❌ <b>{row["mesh"]}</b> — {row["reason"]}</div>',
                unsafe_allow_html=True)
        else:
            st.markdown(
                f'<div class="match-skip">⏭ <b>{row["mesh"]}</b> — {row["reason"]}</div>',
                unsafe_allow_html=True)

if not preview_meshes:
    st.error("No meshes could be textured. "
             "Make sure texture filenames share keywords with mesh names.")
    st.stop()

# ── Textured 3D view ──────────────────────────────────────────────────────────
st.markdown('<div class="step-badge">Step 6 — Textured 3D Visualization</div>', unsafe_allow_html=True)

with st.spinner("Rendering textured mesh…"):
    fig_tex = make_textured_fig(preview_meshes, "Textured Mesh")

st.plotly_chart(fig_tex, use_container_width=True)

# Before / After comparison
st.markdown("**Before vs After**")
b1, b2 = st.columns(2)
with b1:
    st.plotly_chart(make_plain_fig(scene, "Without Texture"), use_container_width=True)
with b2:
    st.plotly_chart(fig_tex, use_container_width=True)

# ── Texture previews ──────────────────────────────────────────────────────────
st.markdown('<div class="step-badge">Step 7 — Texture Image Previews</div>', unsafe_allow_html=True)
preview_cols = st.columns(min(len(texture_files), 5))
for i, tf in enumerate(texture_files[:10]):
    with preview_cols[i % len(preview_cols)]:
        try:
            tf.seek(0)
            st.image(Image.open(tf), caption=tf.name, use_container_width=True)
        except Exception:
            st.caption(f"⚠️ {tf.name}")

# ── Export ────────────────────────────────────────────────────────────────────
st.markdown('<div class="step-badge">Step 8 — Export</div>', unsafe_allow_html=True)

ec1, ec2 = st.columns(2)

obj_str = export_obj(preview_meshes)
ec1.download_button(
    "⬇ Download Textured OBJ",
    data=obj_str.encode(),
    file_name="textured_mesh.obj",
    mime="text/plain"
)

zip_buf = io.BytesIO()
with zipfile.ZipFile(zip_buf, "w", zipfile.ZIP_DEFLATED) as zf:
    zf.writestr("textured_mesh.obj", obj_str)
    uv_buf.seek(0)
    zf.writestr("uv_atlas.png", uv_buf.read())
    for tf in texture_files:
        try:
            tf.seek(0)
            zf.writestr(f"textures/{tf.name}", tf.read())
        except Exception:
            pass
zip_buf.seek(0)
ec2.download_button(
    "⬇ Download All (ZIP)",
    data=zip_buf.getvalue(),
    file_name="gltf_texture_export.zip",
    mime="application/zip"
)

# Cleanup
shutil.rmtree(tmpdir, ignore_errors=True)

st.markdown("---")
st.caption("Pipeline: trimesh · xatlas · PIL · plotly · matplotlib · streamlit")
