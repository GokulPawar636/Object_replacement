                    st.success(f"✅ UV done  |  {len(uvs):,} UV verts  |  {len(idx2d):,} UV tris")
                    uc, us = st.columns([2,1])
                    with uc:
                        st.subheader("UV Atlas Layout")
                        st.image(uv_figure(uvs, idx2d), use_container_width=True)
                    with us:
                        st.subheader("UV Stats")
                        uv_min=uvs.min(axis=0); uv_max=uvs.max(axis=0)
                        try:
                            px=(np.clip(uvs[:,0],0,1)*511).astype(int)
                            py=(np.clip(uvs[:,1],0,1)*511).astype(int)
                            g=np.zeros((512,512),bool); g[py,px]=True
                            cov=g.sum()/g.size
                        except: cov=0.0
                        for lbl,val in [
                            ("UV Verts",  f"{len(uvs):,}"),
                            ("UV Tris",   f"{len(idx2d):,}"),
                            ("Coverage",  f"{cov*100:.1f}%"),
                            ("U range",   f"{uv_min[0]:.2f}→{uv_max[0]:.2f}"),
                            ("V range",   f"{uv_min[1]:.2f}→{uv_max[1]:.2f}"),
                        ]:
                            st.markdown(
                                f"<div class='metric-box'>"
                                f"<b style='color:#388bfd'>{val}</b><br>"
                                f"<small style='color:#8b949e'>{lbl}</small>"
                                f"</div>", unsafe_allow_html=True)

        # ── Export ────────────────────────────────────────────────────────────
        st.header("💾 Export")
        ec1, ec2, ec3 = st.columns(3)

        quad_obj = export_quad_obj(verts, quads_np, surf_msh.faces)
        ec1.download_button("⬇ Quad OBJ",
            quad_obj.encode(), "mesh_quad.obj", "text/plain")

        stl_buf = io.BytesIO()
        surf_msh.export(stl_buf, file_type="stl"); stl_buf.seek(0)
        ec2.download_button("⬇ Quad STL",
            stl_buf.getvalue(), "mesh_quad.stl")

        # ZIP
        zbuf=io.BytesIO()
        with zipfile.ZipFile(zbuf,"w",zipfile.ZIP_DEFLATED) as zf:
            zf.writestr("mesh_quad.obj", quad_obj)
            stl_buf.seek(0); zf.writestr("mesh_quad.stl", stl_buf.read())
            if st.session_state.get("uv_done"):
                vm=st.session_state["uv_vm"]; idx2d=st.session_state["uv_idx"]
                uvs_=st.session_state["uv_uvs"]
                zf.writestr("mesh_uv.obj", export_uv_obj(surf_msh,vm,idx2d,uvs_))
        zbuf.seek(0)
        ec3.download_button("⬇ All (ZIP)", zbuf.getvalue(), "mesh_export.zip")

        st.markdown("""<div class='hint-box'>
        <b>Open in Blender:</b> File → Import → Wavefront (.obj) → <code>mesh_quad.obj</code>
        — you will see clean quad topology. Switch to Edit Mode + press <b>2</b> to see edge loops.
        </div>""", unsafe_allow_html=True)

