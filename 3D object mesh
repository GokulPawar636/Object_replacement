        color="#c0d8f0", opacity=1.0,
        flatshading=False,
        lighting=dict(ambient=0.45, diffuse=0.8, specular=0.1),
    ))
    if show_wire:
        ex,ey,ez=[],[],[]
        step=max(1,len(f)//3000)
        for tri in f[::step]:
            for a,b in [(tri[0],tri[1]),(tri[1],tri[2]),(tri[2],tri[0])]:
                ex+=[v[a,0],v[b,0],None]; ey+=[v[a,1],v[b,1],None]; ez+=[v[a,2],v[b,2],None]
        wc = WIRE_COLORS[wire_color].replace("X","0.5")
        fig.add_trace(go.Scatter3d(x=ex,y=ey,z=ez,mode="lines",
            line=dict(color=wc,width=0.8),showlegend=False))
    fig.update_layout(
        title=dict(text=title,font=dict(color="#8b949e",size=12)),
        paper_bgcolor="#111318",
        scene=dict(bgcolor="#161b22",
            xaxis=dict(showgrid=False,zeroline=False,showticklabels=False),
            yaxis=dict(showgrid=False,zeroline=False,showticklabels=False),
            zaxis=dict(showgrid=False,zeroline=False,showticklabels=False),
