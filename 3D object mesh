        uv_max = uvs.max(axis=0)

        # Estimate UV coverage via rasterization (robust, no ConvexHull shape issues)
        try:
            uv_flat = np.array(uvs).reshape(-1, 2)   # ensure (N, 2)
            uv_flat = np.clip(uv_flat, 0.0, 1.0)
            grid_res = 256
            grid = np.zeros((grid_res, grid_res), dtype=bool)
            px = (uv_flat[:, 0] * (grid_res - 1)).astype(int)
            py = (uv_flat[:, 1] * (grid_res - 1)).astype(int)
            grid[py, px] = True
            coverage = grid.sum() / grid.size
        except Exception:
            coverage = 0.0

        info_data = {
            "UV verts":    f"{len(uvs):,}",
            "UV triangles": f"{len(indices)//3:,}",
