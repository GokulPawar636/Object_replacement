# ════════════════════════════════════════════════════════════════════════════
#  NAME-BASED TEXTURE MATCHING
# ════════════════════════════════════════════════════════════════════════════

def normalize_name(s: str) -> set:
    s = s.lower()
    for suf in ["_basecolor","_base_color","_diffuse","_albedo","_color",
                "_col","_tex","_texture","_d","_bc","_material","_mat"]:
        s = s.replace(suf, "")
    for pre in ["sm_","mi_","m_","mesh_","geo_","obj_","mat_","texture_","tex_"]:
        if s.startswith(pre): s = s[len(pre):]
    return set(t for t in re.split(r"[^a-z0-9]+", s) if len(t) > 1)


def score_match(mesh_name: str, tex_stem: str) -> int:
    m = normalize_name(mesh_name)
    t = normalize_name(tex_stem)
    if not m or not t: return 0
    overlap = m & t
    if m == t:           return 100
    if m.issubset(t):    return 50 + len(m)
    if overlap:          return len(overlap) * 10
    return 0


def pick_texture(mesh_name: str, texture_files) -> object:
    PREFERRED = ["basecolor","base_color","diffuse","albedo","color","col"]
    preferred = [t for t in texture_files
                 if any(k in t.name.lower() for k in PREFERRED)]
    pool = preferred if preferred else list(texture_files)
    best, best_score = None, 0
    for tex in pool:
        s = score_match(mesh_name, Path(tex.name).stem)
        if s > best_score:
            best, best_score = tex, s
    return best if best_score > 0 else None


# ════════════════════════════════════════════════════════════════════════════
#  LOAD GLTF SCENE  (keeps per-mesh geometry + embedded UVs)
# ════════════════════════════════════════════════════════════════════════════

def load_scene(files) -> tuple:
    """Write all uploaded files to a temp dir, load with trimesh."""
    tmpdir = tempfile.mkdtemp()
    for f in files:
        dest = os.path.join(tmpdir, f.name)
        with open(dest, "wb") as out:
            out.write(f.getbuffer())

    primary = next(
        (os.path.join(tmpdir, f.name) for f in files
         if Path(f.name).suffix.lower() in {".glb",".gltf",".obj",".stl",".ply",".off"}),
        None)

    if not primary:
        st.error("No recognised 3D model file found (.gltf, .glb, .obj …)")
        return None, tmpdir

    try:
        scene = trimesh.load(primary, force="scene")
        if not isinstance(scene, trimesh.Scene):
            scene = trimesh.scene.scene.Scene(geometry={"mesh": scene})
        return scene, tmpdir
    except Exception as e:
        st.error(f"Load error: {e}")
        return None, tmpdir


def clean_mesh(mesh: trimesh.Trimesh) -> trimesh.Trimesh:
    if merge_verts:  mesh.merge_vertices()
    if remove_degen: mesh.update_faces(mesh.nondegenerate_faces())
    if fix_normals:  mesh.fix_normals()
    mesh.remove_unreferenced_vertices()
    return mesh


# ════════════════════════════════════════════════════════════════════════════
#  UV SAMPLING
# ════════════════════════════════════════════════════════════════════════════

def sample_via_embedded_uv(geom: trimesh.Trimesh, img: Image.Image) -> np.ndarray:
    """Sample texture at each vertex using the mesh's own UV coords → RGBA uint8."""
    uv  = np.clip(np.array(geom.visual.uv, dtype=np.float32), 0.0, 1.0)
    tex = np.array(img.convert("RGBA"), dtype=np.uint8)
    H, W = tex.shape[:2]
    px = np.clip((uv[:,0]*(W-1)).astype(int), 0, W-1)
    py = np.clip(((1-uv[:,1])*(H-1)).astype(int), 0, H-1)
    return tex[py, px]   # shape (N_verts, 4)


def sample_via_xatlas(geom: trimesh.Trimesh, img: Image.Image):
    """
    Run xatlas UV unwrap, then sample texture.
    Returns (vertex_colors_per_original_vert [N,4], new_indices, new_uvs, vmapping)
    """
    vm, idx, uvs = xatlas.parametrize(
        geom.vertices.astype(np.float32),
        geom.faces.astype(np.uint32),
        geom.vertex_normals.astype(np.float32)
    )
    vm   = np.clip(np.array(vm,  dtype=np.int32).flatten(),  0, len(geom.vertices)-1)
    uvs2 = np.clip(np.array(uvs, dtype=np.float32).reshape(-1,2), 0.0, 1.0)
    tex  = np.array(img.convert("RGBA"), dtype=np.uint8)
    H, W = tex.shape[:2]
    px = np.clip((uvs2[:,0]*(W-1)).astype(int), 0, W-1)
    py = np.clip(((1-uvs2[:,1])*(H-1)).astype(int), 0, H-1)
    # Map colours back to original vertex indices
    vcols = np.zeros((len(geom.vertices), 4), dtype=np.uint8)
    vcols[vm] = tex[py, px]
    return vcols


# ════════════════════════════════════════════════════════════════════════════
#  MAIN TEXTURE APPLICATION
# ════════════════════════════════════════════════════════════════════════════

def apply_textures(scene: trimesh.Scene, texture_files):
    preview_meshes, match_log = [], []

    for geom_name, geom in scene.geometry.items():
        if not isinstance(geom, trimesh.Trimesh):
            match_log.append({"mesh": geom_name, "status": "skip", "reason": "not a Trimesh"})
            continue

        geom = clean_mesh(geom.copy())

        # ── Check for embedded UV coords ─────────────────────────────────
        has_uv = (
            hasattr(geom.visual, "uv")
            and geom.visual.uv is not None
            and len(geom.visual.uv) == len(geom.vertices)
        )

        # ── Find matching texture ─────────────────────────────────────────
        tex_file = pick_texture(geom_name, texture_files)

        if tex_file is None:
            match_log.append({"mesh": geom_name, "status": "miss", "reason": "no matching texture"})
            continue

        try:
            tex_file.seek(0)
        except Exception:
            pass

        img = Image.open(tex_file).convert("RGBA")

        # ── Apply ─────────────────────────────────────────────────────────
        try:
            if has_uv:
                vcols    = sample_via_embedded_uv(geom, img)
                uv_src   = "embedded GLTF UV"
            elif use_xatlas:
                vcols    = sample_via_xatlas(geom, img)
                uv_src   = "xatlas (generated)"
            else:
                match_log.append({"mesh": geom_name, "status": "skip", "reason": "no UV coords"})
                continue

            preview = geom.copy()
            preview.visual = trimesh.visual.ColorVisuals(mesh=preview, vertex_colors=vcols)
            preview_meshes.append(preview)
            match_log.append({
                "mesh": geom_name, "status": "ok",
                "texture": tex_file.name, "uv_source": uv_src,
                "verts": len(geom.vertices), "faces": len(geom.faces)
            })

        except Exception as e:
            match_log.append({"mesh": geom_name, "status": "miss", "reason": str(e)})

    return preview_meshes, match_log


