def hex_to_rgb(h):
    h = h.lstrip("#")
    return tuple(int(h[i:i+2],16) for i in (0,2,4))


def make_quad_figure(vertices, quads_np, surf_mesh, title="Quad Mesh"):
    v = vertices
    fig = go.Figure()

    # ── Solid face layer ──────────────────────────────────────────────────────
    if len(quads_np) > 0:
        # split quads → tris for Mesh3d
        ti = np.concatenate([quads_np[:,0], quads_np[:,0]])
        tj = np.concatenate([quads_np[:,1], quads_np[:,2]])
        tk = np.concatenate([quads_np[:,2], quads_np[:,3]])
        r,g,b = hex_to_rgb(face_color)
        fig.add_trace(go.Mesh3d(
            x=v[:,0], y=v[:,1], z=v[:,2],
            i=ti, j=tj, k=tk,
            color=f"rgb({r},{g},{b})",
            opacity=1.0,
            flatshading=False,
            lighting=dict(ambient=0.45, diffuse=0.8, specular=0.15,
                          roughness=0.6, fresnel=0.05),
            lightposition=dict(x=100, y=200, z=300),
        ))
    else:
        # fallback: solid triangles
        f = surf_mesh.faces
        fig.add_trace(go.Mesh3d(
            x=v[:,0],y=v[:,1],z=v[:,2],
            i=f[:,0],j=f[:,1],k=f[:,2],
            color=face_color, opacity=1.0,
        ))

    # ── Quad wireframe grid ───────────────────────────────────────────────────
    if show_wire and len(quads_np) > 0:
        ex, ey, ez = [], [], []
        step = max(1, len(quads_np) // 4000)
        for q in quads_np[::step]:
            # draw 4 edges of the quad (no diagonal)
            for a, b in [(q[0],q[1]),(q[1],q[2]),(q[2],q[3]),(q[3],q[0])]:
                ex += [v[a,0], v[b,0], None]
                ey += [v[a,1], v[b,1], None]
                ez += [v[a,2], v[b,2], None]
        wc = WIRE_COLORS[wire_color].replace("X", str(wire_opacity))
        fig.add_trace(go.Scatter3d(
            x=ex, y=ey, z=ez, mode="lines",
            line=dict(color=wc, width=1.2),
            showlegend=False,
        ))

    fig.update_layout(
        title=dict(text=title, font=dict(color="#79c0ff", size=13)),
        paper_bgcolor="#111318",
        scene=dict(
            bgcolor="#161b22",
            xaxis=dict(showgrid=False, zeroline=False, showticklabels=False),
            yaxis=dict(showgrid=False, zeroline=False, showticklabels=False),
            zaxis=dict(showgrid=False, zeroline=False, showticklabels=False),
            aspectmode="data",
        ),
        margin=dict(l=0, r=0, t=45, b=0),
        font=dict(color="#8b949e"),
        showlegend=False,
    )
    return fig


def make_original_figure(mesh, title="Original"):
