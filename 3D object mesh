def export_quad_obj(vertices, quads_np, fallback_faces=None):
    lines=["# Quad mesh OBJ",""]
    for vv in vertices:
        lines.append(f"v {vv[0]:.6f} {vv[1]:.6f} {vv[2]:.6f}")
    lines.append("")
    if len(quads_np)>0:
        for q in quads_np:
            lines.append(f"f {q[0]+1} {q[1]+1} {q[2]+1} {q[3]+1}")
    elif fallback_faces is not None:
        for tri in fallback_faces:
            lines.append(f"f {tri[0]+1} {tri[1]+1} {tri[2]+1}")
    return "\n".join(lines)


def export_uv_obj(mesh, vmapping, indices_2d, uvs_2d):
    vm  = np.clip(np.array(vmapping,np.int32).flatten(), 0, len(mesh.vertices)-1)
    idx = indices_2d.flatten()
    mx  = len(uvs_2d)-1
    nv  = mesh.vertices[vm]
    lines=["# UV-mapped OBJ",""]
    for vv in nv: lines.append(f"v {vv[0]:.6f} {vv[1]:.6f} {vv[2]:.6f}")
    lines.append("")
    for uv in uvs_2d: lines.append(f"vt {uv[0]:.6f} {uv[1]:.6f}")
    lines.append("")
    for i in range(0,len(idx)-2,3):
        a=int(np.clip(idx[i],  0,mx))+1
        b=int(np.clip(idx[i+1],0,mx))+1
        c=int(np.clip(idx[i+2],0,mx))+1
        lines.append(f"f {a}/{a} {b}/{b} {c}/{c}")
    return "\n".join(lines)


