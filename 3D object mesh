def load_mesh_from_uploads(files: list) -> trimesh.Trimesh | None:
    """Write uploads to temp dir, load with trimesh."""
    with tempfile.TemporaryDirectory() as tmpdir:
        saved = {}
        for f in files:
            dest = os.path.join(tmpdir, f.name)
            with open(dest, "wb") as out:
                out.write(f.getbuffer())
            saved[f.name] = dest

        # Find the primary model file
        primary = None
        for name, path in saved.items():
            ext = Path(name).suffix.lower()
            if ext in {".glb", ".gltf", ".obj", ".stl", ".ply", ".off"}:
                primary = path
                break

        if primary is None:
            return None

        try:
            scene_or_mesh = trimesh.load(primary, force="mesh")
            if isinstance(scene_or_mesh, trimesh.Scene):
                meshes = [g for g in scene_or_mesh.geometry.values()
                          if isinstance(g, trimesh.Trimesh)]
                if not meshes:
                    st.error("Scene contains no triangle meshes.")
                    return None
                mesh = trimesh.util.concatenate(meshes)
            else:
                mesh = scene_or_mesh
            return mesh
        except Exception as e:
            st.error(f"Failed to load model: {e}")
            return None


def clean_mesh(mesh: trimesh.Trimesh) -> trimesh.Trimesh:
    if merge_verts:
        mesh.merge_vertices()
    if remove_degen:
        mask = mesh.nondegenerate_faces()
        mesh.update_faces(mask)
    if fix_normals:
        mesh.fix_normals()
    if fill_holes:
        trimesh.repair.fill_holes(mesh)
    mesh.remove_unreferenced_vertices()
    return mesh


def make_3d_figure(mesh: trimesh.Trimesh, title="3D Mesh") -> go.Figure:
    v, f = mesh.vertices, mesh.faces
    fig = go.Figure()

    # Solid faces
    fig.add_trace(go.Mesh3d(
        x=v[:, 0], y=v[:, 1], z=v[:, 2],
        i=f[:, 0], j=f[:, 1], k=f[:, 2],
        color="#00aaff", opacity=0.7,
        name="Mesh", showscale=False,
        lighting=dict(ambient=0.4, diffuse=0.8, specular=0.2),
    ))

    # Wireframe edges (subsample for performance)
    edges_x, edges_y, edges_z = [], [], []
    step = max(1, len(f) // 2000)
    for tri in f[::step]:
        for a, b in [(tri[0], tri[1]), (tri[1], tri[2]), (tri[2], tri[0])]:
            edges_x += [v[a, 0], v[b, 0], None]
            edges_y += [v[a, 1], v[b, 1], None]
            edges_z += [v[a, 2], v[b, 2], None]
    fig.add_trace(go.Scatter3d(
        x=edges_x, y=edges_y, z=edges_z,
        mode="lines",
        line=dict(color="#00d4ff", width=1),
        opacity=wireframe_opacity,
        name="Wireframe",
    ))

    if show_normals:
        centers = v[f].mean(axis=1)[::max(1, len(f)//500)]
        norms   = mesh.face_normals[::max(1, len(f)//500)] * 0.15
        for c, n in zip(centers, norms):
            fig.add_trace(go.Scatter3d(
                x=[c[0], c[0]+n[0]], y=[c[1], c[1]+n[1]], z=[c[2], c[2]+n[2]],
                mode="lines", line=dict(color="yellow", width=2),
                showlegend=False,
            ))

    fig.update_layout(
        title=title,
        paper_bgcolor="#0e1117",
        plot_bgcolor="#0e1117",
        scene=dict(
            bgcolor="#1a1f2e",
            xaxis=dict(showgrid=False, zeroline=False),
            yaxis=dict(showgrid=False, zeroline=False),
            zaxis=dict(showgrid=False, zeroline=False),
        ),
        margin=dict(l=0, r=0, t=40, b=0),
        font=dict(color="#7ec8e3"),
    )
    return fig


def run_uv_unwrap(mesh: trimesh.Trimesh):
    """Run xatlas UV unwrapping; returns (vmapping, indices, uvs)."""
    positions = mesh.vertices.astype(np.float32)
    faces     = mesh.faces.astype(np.uint32)
    normals   = mesh.vertex_normals.astype(np.float32)

    vmapping, indices, uvs = xatlas.parametrize(positions, faces, normals)
    return vmapping, indices, uvs


def uv_chart_figure(uvs, indices, title="UV Atlas"):
    """Render UV layout using matplotlib."""
    fig, ax = plt.subplots(figsize=(6, 6), facecolor="#1a1f2e")
    ax.set_facecolor("#0e1117")

    # ── Ensure uvs is strictly shape (N, 2) ──────────────────────────────────
    uvs_2d = np.array(uvs, dtype=np.float32).reshape(-1, 2)
    indices_flat = np.array(indices, dtype=np.int32).flatten()

    segs = []
    n_tris = len(indices_flat) // 3
    step = max(1, n_tris // 8000)
    for i in range(0, n_tris, step):
        base = i * 3
        ia, ib, ic = int(indices_flat[base]), int(indices_flat[base+1]), int(indices_flat[base+2])
        # Guard against out-of-bounds indices
        if max(ia, ib, ic) >= len(uvs_2d):
            continue
        ua = uvs_2d[ia].tolist()   # plain [u, v]
        ub = uvs_2d[ib].tolist()
        uc = uvs_2d[ic].tolist()
        segs.append([ua, ub])
        segs.append([ub, uc])
        segs.append([uc, ua])

    lc = mc.LineCollection(segs, colors="#00d4ff", linewidths=0.4, alpha=0.6)
    ax.add_collection(lc)
    ax.set_xlim(0, 1); ax.set_ylim(0, 1)
    ax.set_aspect("equal")
    ax.set_title(title, color="#7ec8e3", fontsize=12)
    ax.tick_params(colors="#7ec8e3")
    for spine in ax.spines.values():
        spine.set_edgecolor("#00d4ff44")
    ax.set_xlabel("U", color="#7ec8e3")
    ax.set_ylabel("V", color="#7ec8e3")

    buf = io.BytesIO()
    fig.savefig(buf, format="png", dpi=150, bbox_inches="tight",
                facecolor=fig.get_facecolor())
    buf.seek(0)
    plt.close(fig)
    return buf


def export_obj_with_uv(mesh, vmapping, indices, uvs) -> str:
    """Build OBJ string with UV coordinates."""
    # Normalise all arrays to safe flat shapes
    vmapping_flat = np.array(vmapping, dtype=np.int32).flatten()
    indices_flat  = np.array(indices,  dtype=np.int32).flatten()
    uvs_2d        = np.array(uvs,      dtype=np.float32).reshape(-1, 2)

    # Clamp vmapping so we never exceed mesh.vertices length
    vmapping_flat = np.clip(vmapping_flat, 0, len(mesh.vertices) - 1)
    new_verts = mesh.vertices[vmapping_flat]

    max_uv = len(uvs_2d) - 1  # highest valid UV index

    lines = ["# Exported by 3D Mesh & UV Unwrap Tool", ""]

    for v in new_verts:
        lines.append(f"v {v[0]:.6f} {v[1]:.6f} {v[2]:.6f}")
    lines.append("")

    for uv in uvs_2d:
        lines.append(f"vt {uv[0]:.6f} {uv[1]:.6f}")
    lines.append("")

    for i in range(0, len(indices_flat) - 2, 3):
        # Clamp each index to valid range; OBJ indices are 1-based
        a = int(np.clip(indices_flat[i],   0, max_uv)) + 1
        b = int(np.clip(indices_flat[i+1], 0, max_uv)) + 1
        c = int(np.clip(indices_flat[i+2], 0, max_uv)) + 1
        lines.append(f"f {a}/{a} {b}/{b} {c}/{c}")

    return "\n".join(lines)


