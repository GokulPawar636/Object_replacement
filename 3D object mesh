def load_mesh(files):
    with tempfile.TemporaryDirectory() as tmp:
        primary = None
        for f in files:
            p = os.path.join(tmp, f.name)
            with open(p,"wb") as out: out.write(f.getbuffer())
            if Path(f.name).suffix.lower() in {".glb",".gltf",".obj",".stl",".ply",".off"}:
                primary = p
        if not primary:
            st.error("No 3D model file recognised."); return None
        try:
            loaded = trimesh.load(primary, force="mesh")
            if isinstance(loaded, trimesh.Scene):
                meshes = [g for g in loaded.geometry.values()
                          if isinstance(g, trimesh.Trimesh)]
                loaded = trimesh.util.concatenate(meshes) if meshes else None
            return loaded
        except Exception as e:
            st.error(f"Load failed: {e}"); return None


def clean_mesh(mesh):
    if merge_verts:  mesh.merge_vertices()
    if remove_degen: mesh.update_faces(mesh.nondegenerate_faces())
    if fix_normals:  mesh.fix_normals()
    mesh.remove_unreferenced_vertices()
    return mesh


# ══════════════════════════════════════════════════════════════════════════════
#  STRUCTURED QUAD REMESHING
#  Strategy: voxelize → marching cubes (uniform tris) → pair tris into quads
#  This gives the "quad grid flowing over surface" look from the reference image
# ══════════════════════════════════════════════════════════════════════════════

def make_structured_quads(mesh, res, smooth):
    """
    Build a structured quad mesh:
    1. Voxelize at resolution `res` → uniform cubic lattice
    2. Extract surface (marching cubes) → near-uniform triangles
    3. Laplacian smooth → removes stair-step voxel artifacts
    4. Pair adjacent triangles sharing hypotenuse → quads
    Returns: (vertices, quads_np, surf_mesh, stats)
    """
    pitch = mesh.extents.max() / float(res)
    pitch = max(pitch, 1e-7)

    # Step 1+2: voxelise → surface
    vox  = mesh.voxelized(pitch=pitch)
    surf = vox.marching_cubes

    # Step 3: smooth
    if smooth > 0:
        try:
            surf = trimesh.smoothing.filter_laplacian(surf, iterations=smooth)
        except Exception:
            pass
    surf.fix_normals()
    surf.remove_unreferenced_vertices()

    # Step 4: pair triangles → quads
    faces = surf.faces
    edge_face = defaultdict(list)
    for fi, tri in enumerate(faces):
        for a, b in [(tri[0],tri[1]),(tri[1],tri[2]),(tri[2],tri[0])]:
            key = (min(int(a),int(b)), max(int(a),int(b)))
            edge_face[key].append(fi)

    quads, used = [], set()
    for fi, tri in enumerate(faces):
        if fi in used: continue
        for a, b in [(tri[0],tri[1]),(tri[1],tri[2]),(tri[2],tri[0])]:
            key = (min(int(a),int(b)), max(int(a),int(b)))
            nbs  = [f for f in edge_face[key] if f != fi and f not in used]
            if nbs:
                tj    = faces[nbs[0]]
                all_v = list(set(list(tri) + list(tj)))
                if len(all_v) == 4:
                    # sort quad vertices into consistent winding
                    v0 = surf.vertices[all_v]
                    center = v0.mean(axis=0)
                    angles = np.arctan2(
                        (v0 - center)[:,1],
                        (v0 - center)[:,0]
                    )
                    order = np.argsort(angles)
                    quads.append([all_v[i] for i in order])
                    used.add(fi); used.add(nbs[0])
                    break
        else:
            used.add(fi)

    quads_np = np.array(quads, np.int32) if quads else np.zeros((0,4), np.int32)
    coverage = len(quads_np)*2 / max(len(faces),1) * 100

    stats = {
        "input_faces":  len(mesh.faces),
        "quad_faces":   len(quads_np),
        "vertices":     len(surf.vertices),
        "tri_faces":    len(faces),
        "coverage":     coverage,
        "pitch":        pitch,
        "res":          res,
    }
    return surf.vertices, quads_np, surf, stats


