def _style(fig, title):
    fig.update_layout(
        title=dict(text=title, font=dict(color="#c9d4f0", family="Space Mono", size=13)),
        paper_bgcolor="#080b10", plot_bgcolor="#080b10",
        scene=dict(bgcolor="#0d1420",
                   xaxis=dict(showgrid=False,zeroline=False,showticklabels=False),
                   yaxis=dict(showgrid=False,zeroline=False,showticklabels=False),
                   zaxis=dict(showgrid=False,zeroline=False,showticklabels=False),
                   aspectmode="data"),
        margin=dict(l=0,r=0,t=40,b=0),
        font=dict(color="#8899bb"),
    )


def make_plain_fig(scene: trimesh.Scene, title="Base Mesh") -> go.Figure:
    fig = go.Figure()
    for geom in scene.geometry.values():
        if not isinstance(geom, trimesh.Trimesh): continue
        v, f = geom.vertices, geom.faces
        fig.add_trace(go.Mesh3d(
            x=v[:,0],y=v[:,1],z=v[:,2],
            i=f[:,0],j=f[:,1],k=f[:,2],
            color="#2a5298", opacity=0.85, flatshading=False,
            lighting=dict(ambient=0.5,diffuse=0.8,specular=0.2),
        ))
        step = max(1, len(f)//1500)
        ex,ey,ez=[],[],[]
        for tri in f[::step]:
            for a,b in [(tri[0],tri[1]),(tri[1],tri[2]),(tri[2],tri[0])]:
                ex+=[v[a,0],v[b,0],None]; ey+=[v[a,1],v[b,1],None]; ez+=[v[a,2],v[b,2],None]
        fig.add_trace(go.Scatter3d(x=ex,y=ey,z=ez,mode="lines",
            line=dict(color="#6eaaff",width=1),opacity=wireframe_opacity,showlegend=False))
    _style(fig, title)
    return fig


def make_textured_fig(meshes: list, title="Textured Mesh") -> go.Figure:
    fig = go.Figure()
    for mesh in meshes:
        v, f = mesh.vertices, mesh.faces
        vc   = mesh.visual.vertex_colors
        colors = [f"rgb({c[0]},{c[1]},{c[2]})" for c in vc]
        fig.add_trace(go.Mesh3d(
            x=v[:,0],y=v[:,1],z=v[:,2],
            i=f[:,0],j=f[:,1],k=f[:,2],
            vertexcolor=colors, opacity=1.0, flatshading=False,
        ))
        step = max(1, len(f)//1500)
        ex,ey,ez=[],[],[]
        for tri in f[::step]:
            for a,b in [(tri[0],tri[1]),(tri[1],tri[2]),(tri[2],tri[0])]:
                ex+=[v[a,0],v[b,0],None]; ey+=[v[a,1],v[b,1],None]; ez+=[v[a,2],v[b,2],None]
        fig.add_trace(go.Scatter3d(x=ex,y=ey,z=ez,mode="lines",
            line=dict(color="#000",width=0.4),opacity=wireframe_opacity*0.4,showlegend=False))
    _style(fig, title)
    return fig


