#  UV ATLAS VIEWER
# ════════════════════════════════════════════════════════════════════════════

def render_uv_atlas(scene: trimesh.Scene) -> io.BytesIO:
    fig, ax = plt.subplots(figsize=(5,5), facecolor="#0d1420")
    ax.set_facecolor("#080b10")
    drawn = 0
    for geom in scene.geometry.values():
        if not isinstance(geom, trimesh.Trimesh): continue
        if not (hasattr(geom.visual,"uv") and geom.visual.uv is not None
                and len(geom.visual.uv) == len(geom.vertices)): continue
        uvs  = np.array(geom.visual.uv, dtype=np.float32).reshape(-1,2)
        f    = geom.faces
        step = max(1, len(f)//4000)
        segs = []
        for tri in f[::step]:
            if max(tri) >= len(uvs): continue
            ua,ub,uc = uvs[tri[0]].tolist(), uvs[tri[1]].tolist(), uvs[tri[2]].tolist()
            segs += [[ua,ub],[ub,uc],[uc,ua]]
        if segs:
            lc = mc.LineCollection(segs, colors="#6eaaff", linewidths=0.35, alpha=0.6)
            ax.add_collection(lc); drawn += 1
    ax.set_xlim(0,1); ax.set_ylim(0,1); ax.set_aspect("equal")
    ax.set_title(f"UV Atlas — {drawn} mesh(es)", color="#c9d4f0", fontsize=10)
    ax.set_xlabel("U", color="#4a5a78"); ax.set_ylabel("V", color="#4a5a78")
    ax.tick_params(colors="#4a5a78")
    for s in ax.spines.values(): s.set_edgecolor("#1a2540")
    buf = io.BytesIO()
    fig.savefig(buf, format="png", dpi=150, bbox_inches="tight", facecolor=fig.get_facecolor())
    buf.seek(0); plt.close(fig)
    return buf


