def export_obj(meshes: list) -> str:
    lines = ["# Exported by GLTF Texture Mapper", ""]
    v_offset = 1
    for mesh in meshes:
        v, f = mesh.vertices, mesh.faces
        vc   = mesh.visual.vertex_colors
        for vi in v:  lines.append(f"v {vi[0]:.6f} {vi[1]:.6f} {vi[2]:.6f}")
        for c  in vc: lines.append(f"vc {c[0]} {c[1]} {c[2]}")
        lines.append("")
        for tri in f:
            a,b,c2 = tri[0]+v_offset, tri[1]+v_offset, tri[2]+v_offset
            lines.append(f"f {a} {b} {c2}")
        lines.append("")
        v_offset += len(v)
    return "\n".join(lines)


