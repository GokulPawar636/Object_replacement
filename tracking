# MAIN PIPELINE
# =============================================================================

def process(video_path, conf, mask_mode, out_w, ar_mode, max_lost, smooth_n,
            rot_weight, show_obj_landmarks):
    cap = cv2.VideoCapture(video_path)
    fps = cap.get(cv2.CAP_PROP_FPS) or 25
    ow = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
    oh = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
    total = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    scale = out_w / max(ow, 1)
    out_h = int(oh * scale) & ~1

    tmp = tempfile.NamedTemporaryFile(delete=False, suffix=".mp4").name
    writer = cv2.VideoWriter(tmp, cv2.VideoWriter_fourcc(*"mp4v"), fps, (out_w, out_h))

    Track._ctr = 0
    tracker = Tracker(max_lost=max_lost, rot_weight=rot_weight)
    prog = st.progress(0); preview = st.empty()
    t0 = time.time(); fi = 0

    while True:
        ret, frame = cap.read()
        if not ret: break

        results = yolo(frame, conf=conf, verbose=False)[0]
        dets = []

        if results.masks is not None and results.boxes is not None:
            candidates = []
            for i, cls in enumerate(results.boxes.cls.cpu().numpy()):
                if yolo.names[int(cls)].lower() != "cell phone": continue
                mf = results.masks.data[i].cpu().numpy()
                mask = make_phone_mask(mf, ow, oh, mask_mode)
                if mask is None: continue
                area = int(np.sum(mask > 0))
                bbox = results.boxes.xyxy[i].cpu().numpy().tolist()
                candidates.append((area, bbox, mask))

            candidates.sort(key=lambda x: x[0], reverse=True)
            for area, bbox, mask in candidates[:3]:
                # v6 classification
                face = classify_phone_face(frame, mask)

                # Objectron on crop (for rotation & landmarks)
                rot_vec = None
                obj = None
                if rot_weight > 0 or show_obj_landmarks:
                    R, obj_tmp = run_objectron_on_crop(frame, bbox, pad_pct=0.10)
                    if R is not None:
                        rot_vec = rotation_matrix_to_angle_axis(R)
                        obj = obj_tmp
                dets.append((bbox, face, mask, rot_vec, obj))

        tracks = tracker.step(dets)
        dbg = frame.copy()

        # Build lookup for masks and Objectron data
        lookup = {tuple(bbox): (mask, face, rot_vec, obj) for (bbox, face, mask, rot_vec, obj) in dets}

        for t in tracks:
            best_key, best_iou = None, 0.0
            for key in lookup:
                iou = _iou(t.bbox, list(key))
                if iou > best_iou: best_iou, best_key = iou, key

            face_label = t.smooth_face
            color = FACE_COLORS.get(face_label, t.color)

            if best_key and best_iou > 0.1:
                mask, _, rot_vec, obj = lookup[best_key]

                # Mask overlay
                ov = np.zeros_like(dbg); ov[mask>0] = color
                dbg = cv2.addWeighted(dbg, 1.0, ov, 0.28, 0)

                # Contour
                cnts,_ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
                cv2.drawContours(dbg, cnts, -1, color, 2)

                # Debug ratio
                draw_debug_ratio(dbg, mask, face_label, color)

                # AR from v6 (pose from mask)
                if ar_mode != "Label only":
                    pose = get_pose_for_ar(mask, ow, oh)
                    if pose:
                        rv, tv, K, box2d = pose
                        cv2.polylines(dbg, [box2d.astype(int)], True, color, 2)
                        if ar_mode == "Axes + Label":
                            draw_axes(dbg, rv, tv, K)
                        elif ar_mode == "Box + Label":
                            draw_axes(dbg, rv, tv, K)
                            draw_3d_box(dbg, rv, tv, K)

                # Objectron landmarks (if enabled and available)
                if show_obj_landmarks and obj is not None and best_key is not None:
                    x1,y1,x2,y2 = map(int, best_key)
                    pw = int((x2-x1)*0.10); ph = int((y2-y1)*0.10)
                    cx1 = max(0, x1-pw); cy1 = max(0, y1-ph)
                    cx2 = min(ow, x2+pw); cy2 = min(oh, y2+ph)
                    draw_objectron_landmarks(dbg, obj, cx1, cy1, cx2-cx1, cy2-cy1)

            # Bounding box and labels
            x1,y1,x2,y2 = map(int, t.bbox)
            cv2.rectangle(dbg,(x1,y1),(x2,y2),color,2)
            draw_label(dbg, f"ID {t.id}", (x1, y1-10), color, scale=0.60)
            draw_label(dbg, face_label,   (x1, y2+26), color, scale=0.80)

        out_frame = cv2.resize(dbg, (out_w, out_h), interpolation=cv2.INTER_LINEAR)
        writer.write(out_frame)

        fi += 1
        elapsed = time.time()-t0
        fps_e = fi/max(elapsed,1e-3)
        eta = (total-fi)/max(fps_e,1e-3)
        prog.progress(min(fi/total,1.0),
                      text=f"Frame {fi}/{total} · {fps_e:.1f} fps · ETA {eta:.0f}s")
        if fi % 20 == 0:
            preview.image(cv2.cvtColor(out_frame,cv2.COLOR_BGR2RGB),
                          caption="Preview", use_container_width=True)

    cap.release(); writer.release(); prog.empty(); preview.empty()

    final = tempfile.NamedTemporaryFile(delete=False, suffix=".mp4").name
    subprocess.run([FFMPEG,"-y","-i",tmp,"-c:v","libx264","-preset","fast",
                    "-crf","18","-movflags","+faststart",final],
                   capture_output=True, check=False)
    os.unlink(tmp)
    return final, fi, time.time()-t0

